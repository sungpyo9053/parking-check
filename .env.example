# --- 외부 API ---
# Kakao Developers (https://developers.kakao.com) 에서 발급
KAKAO_REST_API_KEY=
# 서울 열린데이터광장 (https://data.seoul.go.kr) 에서 발급
SEOUL_OPENAPI_KEY=

# --- DB ---
DATABASE_URL=postgresql://sungpyo@localhost:5432/parking
# docker-compose 환경 변수 (옵션)
POSTGRES_USER=parking
POSTGRES_PASSWORD=parking
POSTGRES_DB=parking

# --- 서버/프론트 URL ---
BACKEND_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:5173

# CORS 허용 도메인 (콤마 구분). Vite 가 5173 을 못 잡으면 5174 로 fallback 한다.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
