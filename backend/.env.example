KAKAO_REST_API_KEY=
SEOUL_OPENAPI_KEY=

# --- DB ---
# 아래 두 줄 중 하나만 주석 해제해서 사용. DATABASE_URL 은 필수.
#
# (A) Homebrew 로컬 PostgreSQL — peer/trust 인증, 본인 macOS 계정으로 접속.
#     계정명(<user>)은 `whoami` 결과로 교체.
DATABASE_URL=postgresql://<user>@localhost:5432/parking
#
# (B) docker-compose 의 db 서비스 — POSTGRES_USER / POSTGRES_PASSWORD 와 일치시킬 것.
# DATABASE_URL=postgresql+psycopg2://parking:parking@localhost:5432/parking

BACKEND_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:5173
# 콤마로 구분된 허용 Origin 목록. Vite 가 5173 을 못 잡으면 5174 로 떨어지므로 둘 다 등록.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# --- Web Search fallback (선택) ---
# DB/Kakao 둘 다 결과가 없을 때 마지막 폴백으로 Tavily Web Search 결과를 가져온다.
# 키가 비어있거나 WEB_SEARCH_ENABLED=false 이면 호출 자체를 건너뜀.
TAVILY_API_KEY=
WEB_SEARCH_ENABLED=false

# Naver Search API (Tavily 한도 초과 시 자동 fallback, 한국 블로그/카페 자료 강함)
# 발급: https://developers.naver.com/apps/#/register (검색 API 체크 + WEB 환경)
# 무료 25,000건/일 — 우리 사용량으로는 사실상 무제한
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# YouTube Data API v3 — 핫플 추천에 조회수 가중치로 사용 (무료, 일 10,000 unit)
# 발급: https://console.cloud.google.com → APIs & Services → Credentials
YOUTUBE_API_KEY=

# Anthropic API (LLM 자연어 요약, 선택). 없으면 evidence 묶음만 표시.
# 발급: https://console.anthropic.com → API Keys ($5 무료 크레딧)
# 비용: Haiku 4.5 ≈ 요약 1건 $0.001, 6시간 캐시로 추가 절약
ANTHROPIC_API_KEY=
